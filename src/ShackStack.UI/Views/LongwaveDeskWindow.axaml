<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShackStack.UI.ViewModels"
        x:Class="ShackStack.UI.Views.LongwaveDeskWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280"
        Height="780"
        MinWidth="1040"
        MinHeight="660"
        Title="Longwave Desk"
        Icon="avares://ShackStack.Desktop/Assets/shackstack.ico"
        Background="#0F1117"
        Foreground="#C4C8D8">
  <Grid RowDefinitions="Auto,*" Margin="10">
    <Border Grid.Row="0" Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="Longwave Desk" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Text="Contacts, logbooks, spots, and manual QSO logging."
                     Foreground="#AAB1C7"
                     TextWrapping="Wrap" />
        </StackPanel>
        <Button Grid.Column="1" Content="Refresh Spots" Command="{Binding RefreshLongwaveSpotsCommand}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="1.35*,1*" ColumnSpacing="10">
      <Border Grid.Column="0" Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
          <TextBlock Grid.Row="0" Text="Logbook Browser" FontSize="16" FontWeight="SemiBold" />
          <TextBlock Grid.Row="1" Text="{Binding LongwaveStatus}" Foreground="#7F879B" TextWrapping="Wrap" />
          <TabControl Grid.Row="2">
            <TabItem Header="Contacts">
              <Grid RowDefinitions="*,Auto" RowSpacing="8">
                <ListBox ItemsSource="{Binding LongwaveRecentContacts}"
                         SelectedItem="{Binding SelectedLongwaveRecentContact}"
                         Background="#0C1017"
                         BorderBrush="#1E2128"
                         BorderThickness="1"
                         MinHeight="420">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="Margin" Value="0" />
                    </Style>
                  </ListBox.Styles>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:LongwaveRecentContactItem">
                      <Border Background="#0C1017" Padding="5,3" Margin="0" CornerRadius="2">
                        <Grid ColumnDefinitions="56,50,82,96,*" ColumnSpacing="8" MinHeight="20">
                          <TextBlock Grid.Column="0" Text="{Binding Band}" Foreground="#AAB1C7" FontSize="11" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="1" Text="{Binding Mode}" Foreground="#AFC4FF" FontSize="11" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="2" Text="{Binding FrequencyText}" Foreground="#C4C8D8" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Column="3" Text="{Binding TimeText}" Foreground="#7F879B" FontSize="10.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Column="4" Text="{Binding SummaryText}" Foreground="#E5ECFF" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                  <Button Content="Delete Selected Contact" Command="{Binding DeleteSelectedLongwaveContactCommand}" MinWidth="150" />
                </StackPanel>
              </Grid>
            </TabItem>

            <TabItem Header="Logbooks">
              <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBox Grid.Column="0" Text="{Binding LongwaveNewLogbookName}" Watermark="New logbook name" />
                  <Button Grid.Column="1" Content="Create" Command="{Binding CreateLongwaveLogbookCommand}" MinWidth="80" />
                </Grid>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding LongwaveLogbooks}"
                         SelectedItem="{Binding SelectedLongwaveLogbook}"
                         Background="#0C1017"
                         BorderBrush="#1E2128"
                         BorderThickness="1"
                         MinHeight="420">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:LongwaveLogbookItem">
                      <Border Background="#0C1017" Padding="5,3" Margin="0" CornerRadius="2">
                        <TextBlock Text="{Binding DisplayText}" Foreground="#E5ECFF" FontSize="12" TextTrimming="CharacterEllipsis" />
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                  <Button Content="Delete Selected Logbook" Command="{Binding DeleteSelectedLongwaveLogbookCommand}" MinWidth="150" />
                </StackPanel>
              </Grid>
            </TabItem>
          </TabControl>
        </Grid>
      </Border>

      <Border Grid.Column="1" Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="10">
            <TextBlock Text="Manual Log Entry" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="{Binding LongwaveLogStatus}" Foreground="#AAB1C7" TextWrapping="Wrap" />
            <Grid ColumnDefinitions="84,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Logbook" Foreground="#7F879B" VerticalAlignment="Center" />
              <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding LongwaveLogbooks}" SelectedItem="{Binding SelectedLongwaveLogbook}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:LongwaveLogbookItem">
                    <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Operator" Foreground="#7F879B" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LongwaveLogOperatorCallsign}" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Callsign" Foreground="#7F879B" VerticalAlignment="Center" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LongwaveLogCallsign}" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="Mode" Foreground="#7F879B" VerticalAlignment="Center" />
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding LongwaveLogMode}" />
              <TextBlock Grid.Row="4" Grid.Column="0" Text="Band" Foreground="#7F879B" VerticalAlignment="Center" />
              <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding LongwaveLogBand}" />
              <TextBlock Grid.Row="5" Grid.Column="0" Text="Freq kHz" Foreground="#7F879B" VerticalAlignment="Center" />
              <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding LongwaveLogFrequencyKhz}" />
              <TextBlock Grid.Row="6" Grid.Column="0" Text="RST S/R" Foreground="#7F879B" VerticalAlignment="Center" />
              <Grid Grid.Row="6" Grid.Column="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding LongwaveLogRstSent}" />
                <TextBox Grid.Column="1" Text="{Binding LongwaveLogRstReceived}" />
              </Grid>
              <TextBlock Grid.Row="7" Grid.Column="0" Text="Park" Foreground="#7F879B" VerticalAlignment="Center" />
              <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding LongwaveLogParkReference}" />
              <TextBlock Grid.Row="8" Grid.Column="0" Text="Grid" Foreground="#7F879B" VerticalAlignment="Center" />
              <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding LongwaveLogGridSquare}" />
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Use Rig For Log" Command="{Binding UseRigForLongwaveLogCommand}" MinWidth="120" />
              <Button Content="Log This QSO" Command="{Binding LogCurrentQsoCommand}" MinWidth="108" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>
