<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShackStack.UI.ViewModels"
        x:Class="ShackStack.UI.Views.WsjtxDeskWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1240"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        Title="Weak-Signal Desk"
        Icon="avares://ShackStack.Desktop/Assets/shackstack.ico"
        Background="#0F1117"
        Foreground="#C4C8D8">
  <Grid RowDefinitions="Auto,*" Margin="10">
    <Border Grid.Row="0" Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="Weak-Signal Desk" FontSize="19" FontWeight="SemiBold" />
          <TextBlock Text="FT8, FT4, Q65, WSPR, and related WSJT-X-style modes will live here. The desk is meant to grow into the richer decode-and-sequence workspace while the main panel stays compact." Foreground="#AAB1C7" TextWrapping="Wrap" />
        </StackPanel>
        <Button Grid.Column="1" Content="Clear List" Command="{Binding ClearWsjtxMessagesCommand}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="1.25*,0.75*" ColumnSpacing="10">
      <Border Grid.Column="0" Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <Grid Grid.Row="0" ColumnDefinitions="72,*" ColumnSpacing="10">
            <TextBlock Grid.Column="0" Text="Session" Foreground="#7F879B" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="{Binding WsjtxSessionNotes}" Foreground="#C4C8D8" TextWrapping="Wrap" />
          </Grid>

          <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" RowSpacing="8">
              <TextBlock Grid.Row="0" Text="Band Activity" FontSize="13" FontWeight="SemiBold" Foreground="#D9DCEA" />
              <Grid Grid.Row="1" ColumnDefinitions="50,30,40,40,56,*" ColumnSpacing="5" Margin="0,1,0,2">
                <TextBlock Grid.Column="0" Text="Time" Foreground="#6F778A" FontSize="10" />
                <TextBlock Grid.Column="1" Text="Mode" Foreground="#6F778A" FontSize="10" />
                <TextBlock Grid.Column="2" Text="SNR" Foreground="#6F778A" FontSize="10" />
                <TextBlock Grid.Column="3" Text="DT" Foreground="#6F778A" FontSize="10" />
                <TextBlock Grid.Column="4" Text="Hz" Foreground="#6F778A" FontSize="10" />
                <TextBlock Grid.Column="5" Text="Message" Foreground="#6F778A" FontSize="10" />
              </Grid>
              <Border Grid.Row="2" Background="#080B12" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="6" Padding="8">
                <ListBox ItemsSource="{Binding WsjtxMessages}"
                         SelectedItem="{Binding SelectedWsjtxMessage}"
                         Background="Transparent"
                         BorderThickness="0">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="Margin" Value="0" />
                      <Setter Property="MinHeight" Value="0" />
                      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                      <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                      <Setter Property="Background" Value="Transparent" />
                    </Style>
                  </ListBox.Styles>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:WsjtxMessageItem">
                      <Border Background="{Binding RowBackground}" CornerRadius="2" Padding="4,0" Margin="0,0,0,1">
                        <Grid ColumnDefinitions="50,30,40,40,56,*" ColumnSpacing="5" MinHeight="16">
                          <TextBlock Grid.Column="0" Text="{Binding TimeText}" Foreground="{Binding MetaBrush}" VerticalAlignment="Center" FontSize="10.5" />
                          <Border Grid.Column="1" Background="{Binding BadgeBackground}" CornerRadius="999" Padding="3,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="{Binding BadgeText}" Foreground="{Binding BadgeForeground}" FontSize="8" FontWeight="SemiBold" />
                          </Border>
                          <TextBlock Grid.Column="2" Text="{Binding SnrText}" Foreground="{Binding AccentBrush}" VerticalAlignment="Center" FontSize="10.5" />
                          <TextBlock Grid.Column="3" Text="{Binding DtText}" Foreground="{Binding MetaBrush}" VerticalAlignment="Center" FontSize="10.5" />
                          <TextBlock Grid.Column="4" Text="{Binding HzText}" Foreground="{Binding MetaBrush}" VerticalAlignment="Center" FontSize="10.5" />
                          <TextBlock Grid.Column="5" Text="{Binding MessageText}" Foreground="{Binding MessageBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="10.5" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="8">
              <TextBlock Grid.Row="0" Text="{Binding WsjtxRxFrequencyTitle}" FontSize="13" FontWeight="SemiBold" Foreground="#D9DCEA" />
              <Grid Grid.Row="1" ColumnDefinitions="50,30,40,40,56,*" ColumnSpacing="5" Margin="0,1,0,2">
                <TextBlock Grid.Column="0" Text="Time" Foreground="#6F778A" FontSize="10" />
                <TextBlock Grid.Column="1" Text="Mode" Foreground="#6F778A" FontSize="10" />
                <TextBlock Grid.Column="2" Text="SNR" Foreground="#6F778A" FontSize="10" />
                <TextBlock Grid.Column="3" Text="DT" Foreground="#6F778A" FontSize="10" />
                <TextBlock Grid.Column="4" Text="Hz" Foreground="#6F778A" FontSize="10" />
                <TextBlock Grid.Column="5" Text="Message" Foreground="#6F778A" FontSize="10" />
              </Grid>
              <Border Grid.Row="2" Background="#080B12" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="6" Padding="8">
                <ListBox ItemsSource="{Binding WsjtxRxFrequencyMessages}"
                         SelectedItem="{Binding SelectedWsjtxMessage}"
                         Background="Transparent"
                         BorderThickness="0">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="Margin" Value="0" />
                      <Setter Property="MinHeight" Value="0" />
                      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                      <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                      <Setter Property="Background" Value="Transparent" />
                    </Style>
                  </ListBox.Styles>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:WsjtxMessageItem">
                      <Border Background="{Binding RowBackground}" CornerRadius="2" Padding="4,0" Margin="0,0,0,1">
                        <Grid ColumnDefinitions="50,30,40,40,56,*" ColumnSpacing="5" MinHeight="16">
                          <TextBlock Grid.Column="0" Text="{Binding TimeText}" Foreground="{Binding MetaBrush}" VerticalAlignment="Center" FontSize="10.5" />
                          <Border Grid.Column="1" Background="{Binding BadgeBackground}" CornerRadius="999" Padding="3,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="{Binding BadgeText}" Foreground="{Binding BadgeForeground}" FontSize="8" FontWeight="SemiBold" />
                          </Border>
                          <TextBlock Grid.Column="2" Text="{Binding SnrText}" Foreground="{Binding AccentBrush}" VerticalAlignment="Center" FontSize="10.5" />
                          <TextBlock Grid.Column="3" Text="{Binding DtText}" Foreground="{Binding MetaBrush}" VerticalAlignment="Center" FontSize="10.5" />
                          <TextBlock Grid.Column="4" Text="{Binding HzText}" Foreground="{Binding MetaBrush}" VerticalAlignment="Center" FontSize="10.5" />
                          <TextBlock Grid.Column="5" Text="{Binding MessageText}" Foreground="{Binding MessageBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="10.5" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>
            </Grid>
          </Grid>
        </Grid>
      </Border>

      <StackPanel Grid.Column="1" Spacing="10">
        <Border Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
          <StackPanel Spacing="8">
            <TextBlock Text="Session Control" FontSize="16" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="72,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="Mode" Foreground="#7F879B" VerticalAlignment="Center" />
              <ComboBox Grid.Column="1" ItemsSource="{Binding WsjtxModeOptions}" SelectedItem="{Binding WsjtxSelectedMode}" />
            </Grid>
            <Grid ColumnDefinitions="72,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="Freq" Foreground="#7F879B" VerticalAlignment="Center" />
              <ComboBox Grid.Column="1" ItemsSource="{Binding WsjtxFrequencyOptions}" SelectedItem="{Binding WsjtxSelectedFrequency}" />
            </Grid>
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <CheckBox IsChecked="{Binding WsjtxAutoSequenceEnabled}" Content="Auto Sequence" Margin="0,0,14,6" />
                <CheckBox IsChecked="{Binding WsjtxAutoStageRepliesEnabled}" Content="Auto Stage Replies" Margin="0,0,14,6" />
            </WrapPanel>
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
              <Button Content="Start RX" Command="{Binding StartWsjtxReceiveCommand}" Margin="0,0,8,6" />
              <Button Content="Stop RX" Command="{Binding StopWsjtxReceiveCommand}" Margin="0,0,8,6" />
              <Button Content="Reset" Command="{Binding ResetWsjtxSessionCommand}" Margin="0,0,8,6" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
          <StackPanel Spacing="8">
            <TextBlock Text="Operator" FontSize="16" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="72,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="Call" Foreground="#7F879B" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding WsjtxOperatorCallsign}" Foreground="#C4C8D8" />
            </Grid>
            <Grid ColumnDefinitions="72,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="Grid" Foreground="#7F879B" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding WsjtxOperatorGridSquare}" Foreground="#C4C8D8" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
          <StackPanel Spacing="8">
            <TextBlock Text="Longwave Log" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="{Binding LongwaveLogStatus}" Foreground="#8E97AC" TextWrapping="Wrap" FontSize="10.5" />
            <Grid ColumnDefinitions="72,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="Logbook" Foreground="#7F879B" VerticalAlignment="Center" />
              <ComboBox Grid.Column="1"
                        ItemsSource="{Binding LongwaveLogbooks}"
                        SelectedItem="{Binding SelectedLongwaveLogbook}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:LongwaveLogbookItem">
                    <TextBlock Text="{Binding DisplayText}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
              <Button Content="Use Selected For Log"
                      Command="{Binding UseSelectedWsjtxForLongwaveLogCommand}"
                      Margin="0,0,8,0"
                      Padding="10,4" />
              <Button Content="Log Selected QSO"
                      Command="{Binding LogSelectedWsjtxQsoCommand}"
                      Padding="10,4" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
            <Grid Grid.Row="0" ColumnDefinitions="72,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="Status" Foreground="#7F879B" />
              <TextBlock Grid.Column="1" Text="{Binding WsjtxRxStatus}" Foreground="#C4C8D8" TextWrapping="Wrap" />
            </Grid>
            <Grid Grid.Row="1" ColumnDefinitions="72,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="Clock" Foreground="#7F879B" />
              <TextBlock Grid.Column="1" Text="{Binding WsjtxClockStatus}" Foreground="#C4C8D8" TextWrapping="Wrap" />
            </Grid>
            <Grid Grid.Row="2" ColumnDefinitions="72,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="Cycle" Foreground="#7F879B" />
              <TextBlock Grid.Column="1" Text="{Binding WsjtxCycleDisplay}" Foreground="#C4C8D8" TextWrapping="Wrap" />
            </Grid>
          </Grid>
        </Border>

        <Border Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
          <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto,*" RowSpacing="6">
            <TextBlock Grid.Row="0" Text="Selected Message" FontSize="15" FontWeight="SemiBold" />
            <Border Grid.Row="1" Background="#080B12" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="6" Padding="8" MinHeight="170">
              <TextBlock Text="{Binding WsjtxSelectedMessageText}" Foreground="#C4C8D8" TextWrapping="Wrap" FontSize="11" />
            </Border>
            <Grid Grid.Row="2" RowDefinitions="Auto,Auto" RowSpacing="6">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="{Binding WsjtxRxTrackStatus}" Foreground="#8E97AC" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="10.5" />
                <Button Grid.Column="1" Content="Track This Offset" Command="{Binding TrackSelectedWsjtxOffsetCommand}" Padding="10,4" />
                <Button Grid.Column="2" Content="Reset Track" Command="{Binding ResetWsjtxRxFrequencyTrackCommand}" Padding="10,4" />
              </Grid>
              <Grid Grid.Row="1" ColumnDefinitions="*,74,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <StackPanel Grid.Column="0" Spacing="1">
                  <TextBlock Text="{Binding WsjtxTxFrequencyTitle}" Foreground="#C4C8D8" FontSize="11" />
                  <TextBlock Text="{Binding WsjtxTxTrackStatus}" Foreground="#8E97AC" TextWrapping="Wrap" FontSize="10.5" />
                </StackPanel>
                <TextBox Grid.Column="1" Text="{Binding WsjtxTxAudioFrequencyHz}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" MinWidth="68" />
                <CheckBox Grid.Column="2" IsChecked="{Binding WsjtxHoldTxFrequency}" Content="Hold TX Freq" VerticalAlignment="Center" FontSize="10.5" />
                <Button Grid.Column="3" Content="-100" Command="{Binding NudgeWsjtxTxOffsetDown100Command}" Padding="8,4" />
                <Button Grid.Column="4" Content="-50" Command="{Binding NudgeWsjtxTxOffsetDown50Command}" Padding="8,4" />
                <Button Grid.Column="5" Content="+50" Command="{Binding NudgeWsjtxTxOffsetUp50Command}" Padding="8,4" />
                <Button Grid.Column="6" Content="+100" Command="{Binding NudgeWsjtxTxOffsetUp100Command}" Padding="8,4" />
                <Button Grid.Column="7" Content="TX = RX" Command="{Binding SyncWsjtxTxToRxCommand}" Padding="10,4" />
              </Grid>
            </Grid>
            <TextBlock Grid.Row="3" Text="TX Scaffold" FontSize="15" FontWeight="SemiBold" />
            <Border Grid.Row="4" Background="#080B12" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="6" Padding="8">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                <TextBlock Grid.Row="0" Text="{Binding WsjtxActiveSessionSummary}" Foreground="#8E97AC" TextWrapping="Wrap" FontSize="10.5" />
                <TextBlock Grid.Row="1" Text="{Binding WsjtxTransmitPlanSummary}" Foreground="#AFC4FF" TextWrapping="Wrap" FontSize="10.5" />
                <TextBlock Grid.Row="2" Text="{Binding WsjtxQueuedTransmitPreview}" Foreground="#C4C8D8" TextWrapping="Wrap" FontSize="11" />
                <StackPanel Grid.Row="3" Spacing="6">
                  <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Call CQ Next Slot" Command="{Binding CallWsjtxCqNextSlotCommand}" Margin="0,0,8,0" Padding="10,4" />
                    <Button Content="Send Reply Next Slot" Command="{Binding SendSelectedWsjtxReplyNextSlotCommand}" Margin="0,0,8,0" Padding="10,4" />
                    <Button Content="Stage Selected Message" Command="{Binding StageSelectedWsjtxSuggestedMessageCommand}" Margin="0,0,8,0" Padding="10,4" />
                    <Button Content="Arm Next Slot" Command="{Binding ArmPreparedWsjtxTransmitCommand}" Margin="0,0,8,0" Padding="10,4" />
                    <Button Content="Disarm" Command="{Binding DisarmWsjtxTransmitCommand}" Margin="0,0,8,0" Padding="10,4" />
                    <Button Content="Clear Staged TX" Command="{Binding ClearWsjtxQueuedMessageCommand}" Padding="10,4" />
                  </WrapPanel>
                  <TextBlock Text="{Binding WsjtxTransmitArmSummary}" Foreground="#F0D58A" TextWrapping="Wrap" FontSize="10.5" />
                  <TextBlock Text="{Binding WsjtxPreparedTransmitSummary}" Foreground="#8E97AC" TextWrapping="Wrap" FontSize="10.5" />
                </StackPanel>
              </Grid>
            </Border>
            <TextBlock Grid.Row="5" Text="Suggested Messages" FontSize="15" FontWeight="SemiBold" />
            <Grid Grid.Row="6" RowDefinitions="Auto,*" RowSpacing="6">
              <ListBox Grid.Row="0"
                       ItemsSource="{Binding WsjtxSuggestedMessages}"
                       SelectedItem="{Binding SelectedWsjtxSuggestedMessage}"
                       MaxHeight="120"
                       Background="#080B12"
                       BorderBrush="#1E2128"
                       BorderThickness="1">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:WsjtxSuggestedMessageItem">
                    <Border Padding="6,3" Margin="0,0,0,1" Background="Transparent">
                      <Grid ColumnDefinitions="78,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#AFC4FF" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1" Spacing="1">
                          <TextBlock Text="{Binding Intent}" Foreground="#8E97AC" FontSize="9.5" TextWrapping="Wrap" />
                          <TextBlock Text="{Binding MessageText}" Foreground="#C4C8D8" FontSize="10.5" TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <Border Grid.Row="1" Background="#080B12" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="6" Padding="8" MinHeight="72">
                <TextBlock Text="{Binding WsjtxSuggestedMessagePreview}" Foreground="#C4C8D8" TextWrapping="Wrap" FontSize="10.5" />
              </Border>
            </Grid>
          </Grid>
        </Border>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
