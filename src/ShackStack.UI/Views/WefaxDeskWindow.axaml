<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShackStack.UI.ViewModels"
        x:Class="ShackStack.UI.Views.WefaxDeskWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Title="WeFAX Desk"
        Icon="avares://ShackStack.Desktop/Assets/shackstack.ico"
        Background="#0F1117"
        Foreground="#C4C8D8">
  <Grid RowDefinitions="Auto,*" Margin="10">
    <Border Grid.Row="0" Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="WeFAX Desk" FontSize="19" FontWeight="SemiBold" />
          <TextBlock Text="Received weather fax images live here. The desk is receive-only and keeps an archive of completed captures." Foreground="#AAB1C7" TextWrapping="Wrap" />
        </StackPanel>
        <Button Grid.Column="1" Content="Refresh Archive" Command="{Binding RefreshWefaxArchiveCommand}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="10">
      <Border Grid.Column="0" Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="8">
            <TextBlock Text="Past Images" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="{Binding WefaxReceivedFolderPath, StringFormat=Folder: {0}}" Foreground="#7F879B" TextWrapping="Wrap" />
            <ListBox ItemsSource="{Binding WefaxReceivedImages}" SelectedItem="{Binding SelectedWefaxReceivedImage}" MinHeight="460">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:WefaxImageItem">
                  <StackPanel Spacing="2" Margin="0,2">
                    <TextBlock Text="{Binding Label}" />
                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:g}}" Foreground="#7F879B" FontSize="11" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Border Grid.Column="1" Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
        <Grid RowDefinitions="*,Auto,Auto">
          <Border Background="#080B12" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="6" Padding="12">
            <Image Source="{Binding WefaxSelectedReceivedBitmap}" Stretch="Uniform" />
          </Border>
          <TextBlock Grid.Row="1" Text="{Binding WefaxImageStatus}" Margin="0,10,0,0" Foreground="#AAB1C7" />
          <TextBlock Grid.Row="2" Text="{Binding WefaxSelectedReceivedPath}" Margin="0,6,0,0" Foreground="#7F879B" TextWrapping="Wrap" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
