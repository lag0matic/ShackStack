<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShackStack.UI.ViewModels"
        x:Class="ShackStack.UI.Views.Js8DeskWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1180"
        Height="780"
        MinWidth="960"
        MinHeight="640"
        Title="JS8 Desk"
        Icon="avares://ShackStack.Desktop/Assets/shackstack.ico"
        Background="#0F1117"
        Foreground="#C4C8D8">
  <Grid RowDefinitions="Auto,*" Margin="10">
    <Border Grid.Row="0" Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="3">
          <TextBlock Text="JS8 Desk" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Text="Chat-style weak-signal messaging with live decodes, quick replies, and slot-timed transmit staging."
                     Foreground="#8E97AC"
                     TextWrapping="Wrap" />
        </StackPanel>
        <Button Grid.Column="1" Content="Clear List" Command="{Binding ClearWsjtxMessagesCommand}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="1.4*,0.7*" ColumnSpacing="10">
      <Border Grid.Column="0" Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <Grid Grid.Row="0" ColumnDefinitions="72,*" ColumnSpacing="10">
            <TextBlock Grid.Column="0" Text="Session" Foreground="#7F879B" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="{Binding WsjtxSessionNotes}" Foreground="#C4C8D8" TextWrapping="Wrap" />
          </Grid>

          <Border Grid.Row="1" Background="#080B12" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="6" Padding="8">
            <Grid RowDefinitions="Auto,*" RowSpacing="5">
              <Grid Grid.Row="0" ColumnDefinitions="58,58,46,46,64,*" ColumnSpacing="6">
                <TextBlock Grid.Column="0" Text="Time" Foreground="#6F778A" FontSize="11" />
                <TextBlock Grid.Column="1" Text="Mode" Foreground="#6F778A" FontSize="11" />
                <TextBlock Grid.Column="2" Text="SNR" Foreground="#6F778A" FontSize="11" />
                <TextBlock Grid.Column="3" Text="DT" Foreground="#6F778A" FontSize="11" />
                <TextBlock Grid.Column="4" Text="Hz" Foreground="#6F778A" FontSize="11" />
                <TextBlock Grid.Column="5" Text="Message" Foreground="#6F778A" FontSize="11" />
              </Grid>

              <ListBox Grid.Row="1"
                       ItemsSource="{Binding WsjtxMessages}"
                       SelectedItem="{Binding SelectedWsjtxMessage}"
                       Background="Transparent"
                       BorderThickness="0">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="2" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#18263A" />
                  </Style>
                  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="#2A5D8F" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:WsjtxMessageItem">
                    <Border Background="{Binding RowBackground}" CornerRadius="3" Padding="5,2" Margin="0,0,0,2">
                      <Grid ColumnDefinitions="58,58,46,46,64,*" ColumnSpacing="6">
                        <TextBlock Grid.Column="0" Text="{Binding TimeText}" Foreground="{Binding MetaBrush}" VerticalAlignment="Center" FontSize="11" />
                        <Border Grid.Column="1" Background="{Binding BadgeBackground}" CornerRadius="999" Padding="4,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                          <TextBlock Text="{Binding ModeText}" Foreground="{Binding BadgeForeground}" FontSize="9" FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding SnrText}" Foreground="{Binding AccentBrush}" VerticalAlignment="Center" FontSize="11" />
                        <TextBlock Grid.Column="3" Text="{Binding DtText}" Foreground="{Binding MetaBrush}" VerticalAlignment="Center" FontSize="11" />
                        <TextBlock Grid.Column="4" Text="{Binding HzText}" Foreground="{Binding MetaBrush}" VerticalAlignment="Center" FontSize="11" />
                        <TextBlock Grid.Column="5" Text="{Binding MessageText}" Foreground="{Binding MessageBrush}" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10">
          <Border Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
            <StackPanel Spacing="8">
              <TextBlock Text="Receive Control" FontSize="16" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="80,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="Submode" Foreground="#7F879B" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding Js8ModeOptions}" SelectedItem="{Binding Js8SelectedMode}" />
              </Grid>
              <Grid ColumnDefinitions="80,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="Band" Foreground="#7F879B" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding Js8FrequencyOptions}" SelectedItem="{Binding Js8SelectedFrequency}" />
              </Grid>
              <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Start JS8 RX" Command="{Binding StartJs8ReceiveCommand}" Margin="0,0,8,6" />
                <Button Content="Stop RX" Command="{Binding StopWsjtxReceiveCommand}" Margin="0,0,8,6" />
                <Button Content="Reset" Command="{Binding ResetWsjtxSessionCommand}" Margin="0,0,8,6" />
              </WrapPanel>
              <TextBlock Text="{Binding Js8SelectedDecodeSummary}" Foreground="#AFC4FF" TextWrapping="Wrap" FontSize="11" />
              <Button Content="Use Selected Decode"
                      Command="{Binding UseSelectedJs8DecodeCommand}"
                      HorizontalAlignment="Left"
                      Padding="10,4" />
            </StackPanel>
          </Border>

          <Border Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
            <StackPanel Spacing="8">
              <TextBlock Text="Status" FontSize="16" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="80,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="RX" Foreground="#7F879B" />
                <TextBlock Grid.Column="1" Text="{Binding WsjtxRxStatus}" TextWrapping="Wrap" />
              </Grid>
              <Grid ColumnDefinitions="80,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="Clock" Foreground="#7F879B" />
                <TextBlock Grid.Column="1" Text="{Binding WsjtxClockStatus}" TextWrapping="Wrap" />
              </Grid>
              <Grid ColumnDefinitions="80,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="Cycle" Foreground="#7F879B" />
                <TextBlock Grid.Column="1" Text="{Binding WsjtxCycleDisplay}" TextWrapping="Wrap" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="#111827" BorderBrush="#24304A" BorderThickness="1" CornerRadius="8" Padding="10">
            <StackPanel Spacing="8">
              <TextBlock Text="Compose Staging" FontSize="16" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="76,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="Target" Foreground="#7F879B" VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         Text="{Binding Js8TargetCallsign, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="Selected station call"
                         MaxLength="12" />
              </Grid>
              <TextBlock Text="{Binding Js8TargetSummary}" Foreground="#9BE7FF" TextWrapping="Wrap" FontSize="11" />
              <Grid ColumnDefinitions="76,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="Message" Foreground="#7F879B" VerticalAlignment="Top" />
                <TextBox Grid.Column="1"
                         Text="{Binding Js8ComposeText, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="Type JS8 text or choose a quick message"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="72"
                         MaxLength="240" />
              </Grid>
              <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Stage CQ" Command="{Binding StageJs8CqCommand}" Margin="0,0,8,6" Padding="10,4" />
                <Button Content="Heartbeat" Command="{Binding StageJs8HeartbeatCommand}" Margin="0,0,8,6" Padding="10,4" />
                <Button Content="Use Quick Message" Command="{Binding StageSelectedJs8SuggestedMessageCommand}" Margin="0,0,8,6" Padding="10,4" />
                <Button Content="Prepare TX" Command="{Binding PrepareJs8TransmitCommand}" Margin="0,0,8,6" Padding="10,4" />
                <Button Content="Arm Next Slot" Command="{Binding PrepareAndArmJs8TransmitCommand}" Margin="0,0,8,6" Padding="10,4" />
                <Button Content="Disarm" Command="{Binding DisarmWsjtxTransmitCommand}" Margin="0,0,8,6" Padding="10,4" />
                <Button Content="Clear" Command="{Binding ClearJs8ComposeCommand}" Margin="0,0,8,6" Padding="10,4" />
              </WrapPanel>
              <TextBlock Text="{Binding Js8ComposeStatus}" Foreground="#F0D58A" TextWrapping="Wrap" FontSize="11" />
              <TextBlock Text="{Binding Js8TransmitReadiness}" Foreground="#8E97AC" TextWrapping="Wrap" FontSize="10.5" />
            </StackPanel>
          </Border>

          <Border Background="#121620" BorderBrush="#1E2128" BorderThickness="1" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,*" RowSpacing="6">
              <TextBlock Grid.Row="0" Text="Quick Messages" FontSize="16" FontWeight="SemiBold" />
              <ListBox Grid.Row="1"
                       ItemsSource="{Binding Js8SuggestedMessages}"
                       SelectedItem="{Binding SelectedJs8SuggestedMessage}"
                       MaxHeight="180"
                       Background="#080B12"
                       BorderBrush="#1E2128"
                       BorderThickness="1">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:WsjtxSuggestedMessageItem">
                    <Border Padding="7,4" Margin="0,0,0,1" Background="Transparent">
                      <Grid ColumnDefinitions="86,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#AFC4FF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1" Spacing="1">
                          <TextBlock Text="{Binding Intent}" Foreground="#8E97AC" FontSize="10" TextWrapping="Wrap" />
                          <TextBlock Text="{Binding MessageText}" Foreground="#C4C8D8" FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>

          <Border Background="#111827" BorderBrush="#24304A" BorderThickness="1" CornerRadius="8" Padding="10">
            <StackPanel Spacing="6">
              <TextBlock Text="TX Notes" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="Text is staged for the next JS8 transmit slot and sent through the normal timed PTT path."
                         Foreground="#AAB1C7"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</Window>
